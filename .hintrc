{
  "extends": ["development"],
  "connector": {
    "name": "local",
    "options": {
      "pattern": [
        "**",
        "!.git/**",
        "!**/node_modules/**",
        "!**/.venv/**",
        "!**/.venv-*/**",
        "!**/__pycache__/**",
        "!**/.pytest_cache/**"
      ]
    }
  }
}
