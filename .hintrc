{
  "extends": ["development"],
  "ignoredUrls": [
    {
      "domain": ".*node_modules.*",
      "hints": ["meta-viewport"]
    }
  ],
  "connector": {
    "name": "local",
    "options": {
      "pattern": [
        "**",
        "!.git/**",
        "!**/node_modules/**",
        "!**/.venv/**",
        "!**/.venv-*/**",
        "!**/__pycache__/**",
        "!**/.pytest_cache/**"
      ]
    }
  }
}
