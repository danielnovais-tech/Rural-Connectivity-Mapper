{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Pytest (repo)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "-q",
        "tests",
        "--rootdir",
        "${workspaceFolder}",
        "-c",
        "${workspaceFolder}/pytest.ini"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Pytest (repo, no capture)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "-q",
        "tests",
        "--rootdir",
        "${workspaceFolder}",
        "-c",
        "${workspaceFolder}/pytest.ini",
        "--capture=no"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
